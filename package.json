{
  "name": "sortofremoteng",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "next build",
    "stage:opkssh-vendor": "node ./scripts/stage-opkssh-vendor.mjs",
    "stage:opkssh-vendor:enable": "node ./scripts/stage-opkssh-vendor.mjs --enable",
    "stage:opkssh-vendor:disable": "node ./scripts/stage-opkssh-vendor.mjs --disable",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs --run",
    "test:coverage": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs --run --coverage",
    "test:import-export": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs --config vitest.import-export.config.ts --run",
    "test:coverage:import-export": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs --config vitest.import-export.config.ts --run --coverage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --no-default-features --features full",
    "tauri:build": "tauri build --no-default-features --features full",
    "turbo:dev": "turbo dev",
    "turbo:build": "turbo build",
    "e2e:smoke:up": "docker compose -f e2e/docker-compose.yml --env-file e2e/.env up -d test-ssh",
    "e2e:smoke:down": "docker compose -f e2e/docker-compose.yml --env-file e2e/.env down -v",
    "e2e:smoke:required": "cargo test --manifest-path src-tauri/Cargo.toml -p sorng-ssh --features docker-e2e --test golden_path -- --include-ignored && cargo test --manifest-path src-tauri/Cargo.toml -p sorng-sftp --features docker-e2e --test golden_path -- --include-ignored",
    "e2e": "wdio run e2e/wdio.conf.ts",
    "e2e:docker:up": "docker compose -f e2e/docker-compose.yml --env-file e2e/.env up -d",
    "e2e:docker:down": "docker compose -f e2e/docker-compose.yml --env-file e2e/.env down -v",
    "e2e:docker:extended:up": "docker compose -f e2e/docker-compose.yml -f docker/compose.e2e.yml --env-file e2e/.env up -d",
    "e2e:docker:extended:down": "docker compose -f e2e/docker-compose.yml -f docker/compose.e2e.yml --env-file e2e/.env down -v --remove-orphans"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "file-saver": "^2.0.5",
    "gifenc": "^1.0.3",
    "guacamole-common-js": "^1.5.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb": "^8.0.3",
    "ipaddr.js": "^2.4.0",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "novnc": "^1.2.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-grid-layout": "^2.2.3",
    "react-i18next": "^17.0.6",
    "react-resizable": "^3.1.3",
    "react-resizable-panels": "^4.11.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "socks": "^2.8.8",
    "sql.js": "^1.14.1",
    "webssh2-frontend": "^1.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/guacamole-common-js": "^1.5.5",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.6.0",
    "@types/novnc": "^0.0.27",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^2.1.0",
    "@types/react-resizable": "^3.0.8",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@wdio/cli": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "@wdio/tauri-service": "^1.0.0",
    "@wdio/types": "^9.27.1",
    "@webgpu/types": "^0.1.69",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "expect-webdriverio": "^5.6.5",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "webdriverio": "^9.27.1"
  },
  "overrides": {
    "@wdio/native-utils": "2.3.0"
  }
}
