{
  "name": "sortofremoteng",
  "private": true,
  "version": "26.8.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "version:check": "node ./scripts/sync-version.mjs --check",
    "version:sync": "node ./scripts/sync-version.mjs --write",
    "version:test": "node --test ./tests/versioning/versioning.test.mjs",
    "release:test": "node --test ./tests/release/*.test.mjs",
    "dev": "node ./scripts/dev-server.mjs",
    "dev:check": "node ./scripts/dev-server.mjs --check",
    "build": "next build",
    "stage:opkssh-vendor": "node ./scripts/stage-opkssh-vendor.mjs",
    "stage:opkssh-vendor:enable": "node ./scripts/stage-opkssh-vendor.mjs --enable",
    "stage:opkssh-vendor:disable": "node ./scripts/stage-opkssh-vendor.mjs --disable",
    "start": "next start",
    "lint": "eslint .",
    "format": "node ./scripts/format-changed.mjs --check",
    "format:write": "node ./scripts/format-changed.mjs --write",
    "test": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs --run",
    "test:coverage": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs --run --coverage",
    "test:import-export": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs --config vitest.import-export.config.ts --run",
    "test:coverage:import-export": "node --max-old-space-size=4096 ./node_modules/vitest/vitest.mjs --config vitest.import-export.config.ts --run --coverage",
    "e2e:fixtures:prepare": "node ./scripts/ci/e2e-http-fixtures.mjs prepare",
    "e2e:fixtures:validate": "node ./scripts/ci/e2e-http-fixtures.mjs validate",
    "e2e:fixtures:test": "node --test ./tests/e2e-http-fixtures/*.test.mjs",
    "tauri": "tauri",
    "tauri:dev": "node ./scripts/tauri-dev.mjs --features full-dev -- --no-default-features",
    "tauri:build": "node ./scripts/native-build-env.mjs tauri build --features full -- --no-default-features",
    "turbo:dev": "turbo dev",
    "turbo:build": "turbo build",
    "e2e:smoke:up": "docker compose -f e2e/docker-compose.yml --env-file e2e/.env up -d test-ssh",
    "e2e:smoke:down": "docker compose -f e2e/docker-compose.yml --env-file e2e/.env down -v",
    "e2e:smoke:required": "node ./scripts/native-build-env.mjs cargo test --manifest-path src-tauri/Cargo.toml -p sorng-ssh --features docker-e2e --test golden_path -- --include-ignored && node ./scripts/native-build-env.mjs cargo test --manifest-path src-tauri/Cargo.toml -p sorng-sftp --features docker-e2e --test golden_path -- --include-ignored",
    "e2e": "wdio run e2e/wdio.conf.ts",
    "e2e:docker:up": "npm run e2e:fixtures:prepare && docker compose -f e2e/docker-compose.yml --env-file e2e/.env up -d",
    "e2e:docker:down": "docker compose -f e2e/docker-compose.yml --env-file e2e/.env down -v",
    "e2e:docker:extended:up": "npm run e2e:fixtures:prepare && docker compose -f e2e/docker-compose.yml -f docker/compose.e2e.yml --env-file e2e/.env up -d",
    "e2e:docker:extended:down": "docker compose -f e2e/docker-compose.yml -f docker/compose.e2e.yml --env-file e2e/.env down -v --remove-orphans",
    "screenshot:readme": "node ./scripts/readme-screenshot.mjs",
    "screenshot:readme:validate": "node ./scripts/readme-screenshot-validation.mjs",
    "screenshot:readme:test": "node --test ./tests/readme-screenshot/*.test.mjs"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "file-saver": "^2.0.5",
    "gifenc": "^1.0.3",
    "guacamole-common-js": "^1.5.0",
    "i18next": "^26.1.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb": "^8.0.3",
    "ipaddr.js": "^2.4.0",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "next": "^16.2.11",
    "novnc": "^1.2.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-grid-layout": "^2.2.3",
    "react-i18next": "^17.0.7",
    "react-resizable-panels": "^4.11.1",
    "react-zoom-pan-pinch": "^4.0.3",
    "socks": "^2.8.9",
    "sql.js": "^1.14.1",
    "webssh2-frontend": "^1.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/guacamole-common-js": "^1.5.5",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.7.0",
    "@types/novnc": "^0.0.27",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^2.1.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@wdio/cli": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "@wdio/tauri-service": "^1.0.0",
    "@wdio/types": "^9.27.1",
    "@webgpu/types": "^0.1.70",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.11",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "expect-webdriverio": "^5.6.5",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.5",
    "webdriverio": "^9.27.1"
  },
  "overrides": {
    "@wdio/native-utils": "2.4.0",
    "next": {
      "postcss": "8.5.17",
      "sharp": "0.35.3"
    },
    "serialize-javascript": "^7.0.7"
  }
}
