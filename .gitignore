*_orig.rs
*_new.rs
*_clean.rs

# SSH key material accidentally generated into the source tree.
# These are short filenames produced by `ssh-keygen -f -f`; the project's
# real keys never live here, so any -f / -f.pub / -f.pin file is junk.
/src-tauri/crates/sorng-ssh/-f
/src-tauri/crates/sorng-ssh/-f.pub
/src-tauri/crates/sorng-ssh/-f.pin

# OPKSSH vendor bundle staging outputs
/src-tauri/crates/sorng-opkssh-vendor/bundle/opkssh/*/sorng_opkssh_vendor.dll
/src-tauri/crates/sorng-opkssh-vendor/bundle/opkssh/*/libsorng_opkssh_vendor.dylib
/src-tauri/crates/sorng-opkssh-vendor/bundle/opkssh/*/libsorng_opkssh_vendor.so
