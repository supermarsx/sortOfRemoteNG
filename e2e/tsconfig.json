{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "@wdio/globals/types",
      "@wdio/mocha-framework",
      "expect-webdriverio",
      "node"
    ]
  },
  "include": [
    "./specs/**/*.ts",
    "./helpers/**/*.ts",
    "./wdio.conf.ts"
  ]
}
